NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/starter
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace_with_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_TOKEN_EXPIRES_IN_MINUTES=60
RESET_TOKEN_EXPIRES_IN_MINUTES=30
APP_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173
AVATAR_STORAGE_DIR=storage/avatars
AVATAR_PUBLIC_BASE_PATH=/media/avatars
AVATAR_MAX_SIZE_BYTES=2097152
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
PUSH_PROVIDER=noop
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
MONETIZATION_MODE=both
SUBSCRIPTION_PERIOD_MODE=both
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_CHECKOUT_SUCCESS_URL=http://localhost:5173/dashboard
MERCADOPAGO_CHECKOUT_FAILURE_URL=http://localhost:5173/dashboard
MERCADOPAGO_CHECKOUT_PENDING_URL=http://localhost:5173/dashboard
MERCADOPAGO_STATEMENT_DESCRIPTOR=STARTERAPP
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=60
PUSH_RATE_LIMIT_WINDOW_MS=60000
PUSH_RATE_LIMIT_MAX=40
