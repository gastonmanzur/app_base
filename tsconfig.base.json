{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@starter/shared-types": ["packages/shared-types/src"],
      "@starter/shared-utils": ["packages/shared-utils/src"],
      "@starter/ui": ["packages/ui/src"]
    }
  }
}
